!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mi Tarjeta de Perfil</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: sans-serif;
      background: #f5f5f5;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }

    /* Tarjeta principal */
    .tarjeta {
      background: white;
      width: 320px;
      padding: 20px;
      border-radius: 15px;
      display: flex;
      flex-direction: column; /* ✅ */
      gap: 15px; /* ✅ */
      box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    /* Header */
    .perfil-header {
      display: flex; /* ✅ */
      align-items: center; /* ✅ */
      gap: 15px; /* ✅ */
    }

    .perfil-header img {
      width: 70px;
      height: 70px;
      border-radius: 50%;
    }

    .info {
      display: flex; /* ✅ */
      flex-direction: column; /* ✅ */
      justify-content: center;
    }

    .info h2 {
      font-size: 18px;
    }

    .info span {
      color: gray;
      font-size: 14px;
    }

    /* Bio */
    .bio {
      font-size: 14px;
      color: #555;
      text-align: center;
    }

    /* Estadísticas */
    .estadisticas {
      display: flex; /* ✅ */
      justify-content: space-between; /* ✅ */
      text-align: center;
    }

    .stat {
      flex: 1; /* ✅ */
    }

    .stat h3 {
      font-size: 16px;
    }

    .stat p {
      font-size: 12px;
      color: gray;
    }

    /* Botones */
    .botones {
      display: flex; /* ✅ */
      justify-content: space-between; /* ✅ */
      gap: 10px; /* ✅ */
    }

    .botones button {
      flex: 1; /* ✅ */
      padding: 10px;
      border: none;
      border-radius: 8px;
      cursor: pointer;
    }

    .seguir {
      background: #2563eb;
      color: white;
    }

    .mensaje {
      background: #e5e7eb;
    }

    /* Miniaturas */
    .miniaturas {
      display: flex; /* ✅ */
      gap: 10px; /* ✅ */
      flex-wrap: wrap; /* ✅ */
      justify-content: center;
    }

    .miniaturas img {
      width: 90px;
      height: 90px;
      border-radius: 10px;
      object-fit: cover;
    }

  </style>
</head>
<body>
  
  <div class="tarjeta">
    
    <!-- Header -->
    <div class="perfil-header">
      <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQMeqyZr0fkjJpWP_G6lpU7i1dWKtFQYrvHvw&s alt="avatar">
      <div class="info">
        <h2>Salomé Muñoz</h2>
        <span>@salo.munoz</span>
      </div>
    </div>
    
    <!-- Bio -->
    <p class="bio">
      Desarrolladora de software y bailarina de tango.
    </p>
    
    <!-- Estadísticas -->
    <div class="estadisticas">
      <div class="stat">
        <h3>3</h3>
        <p>Publicaciones</p>
      </div>
      <div class="stat">
        <h3>567</h3>
        <p>Seguidores</p>
      </div>
      <div class="stat">
        <h3>200</h3>
        <p>Siguiendo</p>
      </div>
    </div>
    
    <!-- Botones -->
    <div class="botones">
      <button class="seguir">Seguir</button>
      <button class="mensaje">Mensaje</button>
    </div>
    
    <!-- Miniaturas -->
    <div class="miniaturas">
      <img src="https://img.freepik.com/vector-gratis/ilustracion-baile-flamenco-dibujado-mano_23-2149917931.jpg?semt=ais_hybrid&w=740&q=80" alt="">
      <img src="https://img.freepik.com/vector-gratis/plantilla-pegatina-miembros-gran-familia-feliz_1308-62600.jpg?semt=ais_hybrid&w=740&q=80" alt="">
      <img src="https://png.pngtree.com/png-clipart/20230913/original/pngtree-buffet-clipart-food-table-of-various-dishes-cartoon-vector-png-image_11065279.png" alt="">
    
  </div>

</body>
</html>